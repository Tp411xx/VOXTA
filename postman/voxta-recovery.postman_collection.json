{
  "info": {
    "name": "VOXTA Recovery",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5001"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "mapId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Ping backend",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/ping"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"player1\",\n  \"email\": \"player1@example.com\",\n  \"password\": \"new_password\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) {",
                  "  pm.collectionVariables.set('token', data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"new_password\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/me"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/admin/users"
          }
        },
        {
          "name": "List all maps",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/admin/maps"
          }
        },
        {
          "name": "Approve map",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"APPROVED\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/maps/{{mapId}}/status"
          }
        }
      ]
    },
    {
      "name": "Maps",
      "item": [
        {
          "name": "Create map",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Demo map\",\n  \"bpm\": 120,\n  \"notes\": [\n    { \"time\": 1, \"lane\": 0 },\n    { \"time\": 1.5, \"lane\": 1 },\n    { \"time\": 2, \"lane\": 2 },\n    { \"time\": 2.5, \"lane\": 3 },\n    { \"time\": 3, \"lane\": 4 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/maps"
          }
        },
        {
          "name": "List approved maps",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/maps"
          }
        }
      ]
    }
  ]
}
